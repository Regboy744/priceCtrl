# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scraping Configuration
SCRAPE_CRON_SCHEDULE=0 6,12,18 * * *
SCRAPE_HEADLESS=true
SCRAPE_TIMEOUT=60000

# Logging
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info
# File logging (auto-enabled in production, disabled in dev)
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5

# Scheduler (set to true to enable cron-based scraping)
ENABLE_SCHEDULER=false

# CORS (comma-separated origins for production)
ALLOWED_ORIGINS=https://yourdomain.com

# ============ Decodo Residential Proxy (rotating / session-aware) ============
# Per-supplier selection lives in src/shared/services/proxy/proxy.config.ts
# → supplierProxyPolicies. Suppliers mapped to "residential" use this pool.
DECODO_PROXY_ENABLED=false

# Auth mode: "ip_whitelist" (production VPS) or "userpass" (development)
DECODO_PROXY_MODE=userpass

# Proxy endpoint — common options:
#   gate.decodo.com:7000  (general backconnect)
#   ie.decodo.com:24001   (Ireland endpoint)
DECODO_PROXY_HOST=gate.decodo.com
DECODO_PROXY_PORT=7000

# Credentials (required only when MODE=userpass)
DECODO_PROXY_USERNAME=
DECODO_PROXY_PASSWORD=

# Protocol for proxy URL (http or https)
DECODO_PROXY_PROTOCOL=http

# Optional: force exit country (ISO 3166-1 alpha-2, e.g. IE, GB, US)
DECODO_PROXY_COUNTRY=

# Session behaviour
# Strategy: "sticky" (same IP for duration) or "rotate" (new IP per request)
DECODO_PROXY_SESSION_STRATEGY=sticky
# Duration in minutes for sticky sessions
DECODO_PROXY_SESSION_DURATION_MIN=30
# Scope: "per_job" | "per_supplier" | "per_browser"
DECODO_PROXY_SESSION_ID_STRATEGY=per_job

# Timeout for proxy test/health requests (ms)
DECODO_PROXY_TIMEOUT_MS=30000

# ============ Decodo ISP / Static Proxy (fixed IPs, unlimited BW) ============
# Plain userpass — no session encoding, IP is already stable.
# Suppliers mapped to "isp" in supplierProxyPolicies route through this pool.
DECODO_ISP_PROXY_ENABLED=false
DECODO_ISP_PROXY_HOST=isp.decodo.com
DECODO_ISP_PROXY_PORT=10001
DECODO_ISP_PROXY_USERNAME=
DECODO_ISP_PROXY_PASSWORD=
DECODO_ISP_PROXY_PROTOCOL=http
DECODO_ISP_PROXY_TIMEOUT_MS=30000
