{
  "name": "retailctrl-backend",
  "version": "1.0.0",
  "description": "RetailCtrl scraping backend - TypeScript + Express + Puppeteer + Supabase",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:proxy": "tsx --env-file=.env scripts/test-proxy.ts"
  },
  "keywords": [
    "scraping",
    "puppeteer",
    "supabase",
    "typescript",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "@pricectrl/contracts": "workspace:*",
    "@supabase/supabase-js": "^2.49.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.0.0",
    "https-proxy-agent": "^7.0.6",
    "lru-cache": "^11.3.5",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "puppeteer": "^23.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "user-agents": "^1.1.669",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pino": "^7.0.5",
    "@types/user-agents": "^1.0.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
