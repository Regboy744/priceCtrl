# Server Configuration
PORT=3000
NODE_ENV=development
OUTPUT_DIR=outputs
USER_DATA_DIR=.playwright-profile
HEADLESS=false

# Shared Supabase database (service role key for server-side writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Chrome path
CHROME_PATH=/usr/bin/google-chrome

# Automated Microsoft login
AUTO_LOGIN=true
MS_USERNAME=your.username@company.com
MS_PASSWORD=replace-with-password
MS_KEEP_SIGNED_IN=false

# Scrape workflow
# Deepest sweep level. Use `commodity` to render before family group selection.
# Supported values: `family` (default), `commodity`
SWEEP_DEPTH=family
REPORT_SURFACE_TIMEOUT_MS=300000
SELECT_DELAY_MS=1000
BROWSER_ACTION_TIMEOUT_MS=15000
SELECT_POSTBACK_TIMEOUT_MS=6000
REPORT_RENDER_TIMEOUT_MS=180000
POST_RENDER_CAPTURE_WAIT_MS=3000
PREFERRED_CAPTURE_TIMEOUT_MS=5000
FORCED_ASYNC_RETRIES=2

# Family-level selection timeout (shorter than BROWSER_ACTION_TIMEOUT_MS).
# Ghost/stale families that don't exist hang the page; a short timeout
# lets the scraper detect and skip them quickly.
FAMILY_SELECT_TIMEOUT_MS=5000

# HTTP replay pacing
REQUEST_DELAY_MS=1000

# Parallel mode: max concurrent isolated browsers (one browser per store).
# Set to 0 or remove to launch all store browsers simultaneously.
MAX_PARALLEL_BROWSERS=10
MAX_FRESH_TAB_RESUMES_PER_STORE=25
STORE_WALL_CLOCK_TIMEOUT_MS=0

# Capture buffer controls (per tab). Keep bounded to avoid memory growth.
CAPTURE_MAX_ITEMS=80
# Set to 0 to disable byte cap.
CAPTURE_MAX_BYTES_MB=20

# Retry and pacing controls for flaky browser failures.
STORE_RETRY_COUNT=1
PARALLEL_BROWSER_STAGGER_MS=300

# HTTP replay resilience for SSRS POST requests.
HTTP_REQUEST_TIMEOUT_MS=45000
HTTP_REQUEST_RETRIES=2
HTTP_REQUEST_RETRY_DELAY_MS=400

# Periodic process memory logging interval in milliseconds.
# Minimum supported value is 5000.
MEM_TELEMETRY_INTERVAL_MS=30000

# Async job concurrency control.
BROWSER_JOB_CONCURRENCY=1

# Optional: force a fresh browser profile (no saved login)
FRESH_PROFILE=false
