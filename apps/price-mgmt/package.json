{
  "name": "ssrs-price-costs",
  "version": "1.0.0",
  "description": "Express API for SSRS price and cost scraping",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/src/server.js",
    "serve": "pnpm build && pnpm start",
    "dev": "tsc && (tsc --watch --preserveWatchOutput &) && sleep 1 && node --watch --env-file-if-exists=.env dist/src/server.js"
  },
  "keywords": [
    "ssrs",
    "express",
    "api",
    "typescript",
    "scraper",
    "playwright"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "axios": "^1.13.6",
    "express": "^5.2.1",
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
