{
  "name": "pricectrl",
  "version": "0.0.0",
  "private": true,
  "description": "PriceCtrl monorepo — backend, frontend, price-mgmt, shared contracts.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0",
